{
  "name": "react-native-nitro-thumbnail",
  "version": "0.1.4",
  "description": "Generate thumbnails from local or remote videos. Nitro-powered, pure Swift & Kotlin, New Architecture, iOS + Android + Web.",
  "main": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "exports": {
    ".": {
      "react-native-nitro-thumbnail-source": "./src/index.ts",
      "types": "./lib/typescript/src/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "cpp",
    "nitrogen",
    "nitro.json",
    "*.podspec",
    "react-native.config.js",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!ios/Tests",
    "!android/src/test",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "example": "yarn workspace react-native-nitro-thumbnail-example",
    "clean": "del-cli android/build example/android/build example/android/app/build example/ios/build lib",
    "prepare": "bob build",
    "nitrogen": "nitrogen",
    "typecheck": "tsc",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "test": "jest"
  },
  "keywords": [
    "react-native",
    "ios",
    "android",
    "web",
    "expo",
    "thumbnail",
    "video-thumbnail",
    "video",
    "nitro",
    "nitro-modules",
    "new-architecture",
    "avfoundation",
    "mediametadataretriever",
    "create-thumbnail"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pythonsst/react-native-nitro-thumbnail.git"
  },
  "author": "Shiv <shiv@cuepilot.ai> (https://github.com/pythonsst)",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "bugs": {
    "url": "https://github.com/pythonsst/react-native-nitro-thumbnail/issues"
  },
  "homepage": "https://github.com/pythonsst/react-native-nitro-thumbnail#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@react-native/babel-preset": "0.86.0",
    "@react-native/eslint-config": "0.86.0",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.0",
    "babel-jest": "^30.4.1",
    "del-cli": "^7.0.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-ft-flow": "^3.0.11",
    "eslint-plugin-prettier": "^5.5.6",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "nitrogen": "^0.36.1",
    "prettier": "^3.8.3",
    "react": "19.2.7",
    "react-native": "0.86.0",
    "react-native-builder-bob": "^0.43.0",
    "react-native-nitro-modules": "^0.36.1",
    "turbo": "^2.9.16",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*",
    "react-native-nitro-modules": "^0.36.1"
  },
  "workspaces": [
    "example"
  ],
  "packageManager": "yarn@4.11.0",
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "custom",
        {
          "script": "nitrogen",
          "clean": "nitrogen/"
        }
      ],
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  },
  "create-react-native-library": {
    "type": "nitro-module",
    "languages": "kotlin-swift",
    "tools": [
      "eslint"
    ],
    "version": "0.63.0"
  }
}
